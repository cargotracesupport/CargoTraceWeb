# ── Supabase ──────────────────────────────────────────────
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Project Settings → API → service_role secret. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ── Map tiles ─────────────────────────────────────────────
# Free key from https://www.maptiler.com/
NEXT_PUBLIC_MAPTILER_KEY=your-maptiler-key

# ── App ───────────────────────────────────────────────────
# Public base URL (used to build customer tracking links). No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000
